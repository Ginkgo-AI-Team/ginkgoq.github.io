---
const navLinks = [
  { href: "/blog/", label: "Blog" },
  { href: "/research-notes/", label: "Research Notes" },
  { href: "/about/", label: "About" },
  { href: "mailto:hello@ginkgoq.ai", label: "Contact" },
];

const topics = [
  "AI Systems",
  "Domain Intelligence",
  "RAG",
  "Agents",
  "Pipelines",
  "Datasets",
  "Production",
  "Evaluation",
];
---

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a class="footer-brand-link" href="/" aria-label="GinkgoQ home">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="22" height="22" fill="currentColor">
              <path d="M25.7 5.9C17.4 5.7 9.5 10.8 6.4 18.5c5.7-2.7 11.6-3.5 17.8-2.6-5.2 1.2-9.9 3.5-14 7.2 6.7 1.6 13.2-1.7 16.4-7.7 1.8-3.4 1.7-6.8-.9-9.5Z" />
            </svg>
          </span>
          <span>GINKGOQ</span>
        </a>
        <p class="footer-brand-desc">Deep-tech AI for real-world systems. Technical writing on AI systems, domain intelligence, and practical AI infrastructure.</p>
        <div class="footer-social" aria-label="Social links">
          <a class="footer-social-link" href="https://github.com/Ginkgo-AI-Team" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" /></svg>
          </a>
          <a class="footer-social-link" href="https://twitter.com/ginkgoai" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
          <a class="footer-social-link" href="mailto:hello@ginkgoq.ai" aria-label="Email">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <span class="footer-col-heading">Navigate</span>
        <ul class="footer-nav-list">
          {navLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col-heading">Topics</span>
        <div class="footer-tag-cloud">
          {topics.map((topic) => <a href={`/blog/?tag=${encodeURIComponent(topic)}`}>{topic}</a>)}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <span>© 2026 GinkgoQ. All rights reserved.</span>
        <div class="footer-bottom-right">
          <a href="mailto:hello@ginkgoq.ai">hello@ginkgoq.ai</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <span>Deep-tech AI for real-world systems</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    transition: background-color 240ms var(--ease), border-color 240ms var(--ease);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.1fr;
    gap: 3rem 4.5rem;
    padding: 4rem 0 3rem;
  }

  .footer-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-decoration: none;
  }

  .footer-brand-link .brand-mark {
    width: 22px;
    height: 22px;
  }

  .footer-brand-desc {
    max-width: 290px;
    margin: 0 0 1.8rem;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.75;
  }

  .footer-social {
    display: flex;
    gap: 0.4rem;
  }

  .footer-social-link {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    color: var(--color-muted);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: color 140ms, border-color 140ms, background-color 140ms;
  }

  .footer-social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
    background: var(--color-accent-soft);
  }

  .footer-col-heading {
    display: block;
    margin: 0 0 1.2rem;
    color: var(--color-subtle);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .footer-nav-list {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-nav-list a {
    color: var(--color-muted);
    font-size: 0.88rem;
    text-decoration: none;
    transition: color 140ms;
  }

  .footer-nav-list a:hover {
    color: var(--color-accent);
  }

  .footer-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .footer-tag-cloud a {
    display: inline-block;
    padding: 0.2rem 0.56rem;
    color: var(--color-muted);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-size: 0.74rem;
    text-decoration: none;
    transition: color 140ms, border-color 140ms, background-color 140ms;
  }

  .footer-tag-cloud a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
    background: var(--color-accent-soft);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 0;
    color: var(--color-subtle);
    font-size: 0.78rem;
  }

  .footer-bottom-inner a {
    color: inherit;
    text-decoration: none;
    transition: color 140ms;
  }

  .footer-bottom-inner a:hover {
    color: var(--color-accent);
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .footer-sep {
    color: var(--color-line);
    user-select: none;
  }

  @media (max-width: 860px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .footer-bottom-right {
      flex-wrap: wrap;
      gap: 0.65rem;
    }
  }
</style>
